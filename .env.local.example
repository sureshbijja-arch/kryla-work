# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI — used for TTS (voice replies in My Chat) and Whisper (voice-to-text transcription)
OPENAI_API_KEY=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# WhatsApp (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Stripe — platform subscription billing (USA)
STRIPE_SECRET_KEY=                           # sk_live_xxx / sk_test_xxx
STRIPE_WEBHOOK_SECRET=                       # whsec_xxx  (from: stripe listen --forward-to ...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=          # pk_live_xxx / pk_test_xxx
STRIPE_CONNECT_WEBHOOK_SECRET=               # separate whsec_xxx for Connect events (Phase 4)
STRIPE_PLATFORM_FEE_BPS=                     # optional application fee in basis points, e.g. 200 = 2%

# Razorpay — platform subscription billing (India, Phase 3) + member-facing (Phase 5)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ROUTE_WEBHOOK_SECRET=               # for member-facing Route webhooks (Phase 5)
NEXT_PUBLIC_RAZORPAY_KEY_ID=                 # exposed to browser for Razorpay Checkout JS

# Resend
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=     # Svix signing secret from Resend → Domains → kryla.work → Receiving → Webhook

# PostHog — observability (errors, analytics, session replay, feature flags)
NEXT_PUBLIC_POSTHOG_KEY=             # phc_xxx  (Project Settings → Project API Key)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # or https://eu.i.posthog.com
POSTHOG_API_KEY=                     # same as NEXT_PUBLIC_POSTHOG_KEY (server-side capture)

# App
NEXT_PUBLIC_APP_URL=https://kryla.work
NEXT_PUBLIC_APP_DOMAIN=kryla.work

# Vercel (custom domain attachment — used by /api/my-space/custom-domain)
VERCEL_API_TOKEN=           # Vercel account token (Account Settings → Tokens)
VERCEL_PROJECT_ID=          # Project → Settings → General → Project ID
VERCEL_TEAM_ID=             # Team → Settings → General → Team ID (omit for personal accounts)
